generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum SaleStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
}

enum InstallmentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  OTHER
}

enum ReminderChannel {
  WHATSAPP
}

enum ReminderTriggerType {
  BEFORE_DUE
  ON_DUE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id               String            @id @default(cuid())
  name             String
  document         String?           @db.VarChar(20)
  phone            String            @db.VarChar(20)
  whatsappPhone    String            @db.VarChar(20)
  email            String?
  notes            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sales            Sale[]
  reminderMessages ReminderMessage[]

  @@index([name])
  @@index([whatsappPhone])
}

model Sale {
  id               String      @id @default(cuid())
  customerId       String
  description      String?
  totalAmount      Decimal     @db.Decimal(10, 2)
  installmentCount Int
  saleDate         DateTime
  notes            String?
  status           SaleStatus  @default(OPEN)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  customer         Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  installments     Installment[]

  @@index([customerId])
  @@index([saleDate])
  @@index([status])
}

model Installment {
  id               String            @id @default(cuid())
  saleId           String
  number           Int
  amount           Decimal           @db.Decimal(10, 2)
  paidAmount       Decimal           @default(0) @db.Decimal(10, 2)
  dueDate          DateTime
  paidAt           DateTime?
  status           InstallmentStatus @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sale             Sale              @relation(fields: [saleId], references: [id], onDelete: Restrict)
  payments         Payment[]
  reminderMessages ReminderMessage[]

  @@unique([saleId, number])
  @@index([saleId])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  installmentId String
  amount        Decimal       @db.Decimal(10, 2)
  paidAt        DateTime
  method        PaymentMethod
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())
  installment   Installment   @relation(fields: [installmentId], references: [id], onDelete: Restrict)

  @@index([installmentId])
  @@index([paidAt])
  @@index([method])
}

model ReminderRule {
  id          String              @id @default(cuid())
  name        String
  triggerType ReminderTriggerType
  daysBefore  Int                 @default(0)
  template    String
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  messages    ReminderMessage[]

  @@unique([triggerType, daysBefore])
  @@index([isActive])
}

model ReminderMessage {
  id                String              @id @default(cuid())
  customerId        String
  installmentId     String
  ruleId            String?
  channel           ReminderChannel     @default(WHATSAPP)
  triggerType       ReminderTriggerType
  triggerDate       DateTime
  scheduledFor      DateTime?
  sentAt            DateTime?
  status            ReminderStatus      @default(PENDING)
  messageBody       String
  providerMessageId String?
  providerPayload   Json?
  errorMessage      String?
  createdAt         DateTime            @default(now())
  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  installment       Installment         @relation(fields: [installmentId], references: [id], onDelete: Restrict)
  rule              ReminderRule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@unique([installmentId, triggerType, triggerDate])
  @@index([customerId])
  @@index([installmentId])
  @@index([ruleId])
  @@index([status])
  @@index([scheduledFor])
  @@index([sentAt])
}

